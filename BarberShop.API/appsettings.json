{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "server=mysql;port=3306;database=barbershop;user=admin;password=admin",
    "Redis": "redis:6379"
  },
  "Jwt": {
    "Key": "SecretKey",
    "Issuer": "BarberShopAPI",
    "Audience": "BarberShopClient",
    "ExpiresInMinutes": 60
  },
  "Google": {
    "ClientId": ""
  },
  "Loyalty": {
    "VisitsForReward": 10
  },
  "Email": {
    "Enabled": false,
    "SmtpHost": "",
    "SmtpPort": 587,
    "SmtpUser": "",
    "SmtpPassword": "",
    "FromAddress": "noreply@barbershop.com",
    "FromName": "BarberShop"
  },
  "Frontend": {
    "BaseUrl": "http://localhost:3000"
  },
  "Reminders": {
    "Enabled": true,
    "IntervalMinutes": 10
  },
  "HealthChecks": {
    "DetailEnabled": true
  },
  "OpenTelemetry": {
    "OtlpEndpoint": "http://localhost:4317"
  }

}
